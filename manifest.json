{
  "manifest_version": 3,
  "name": "YouTube Zoom Enabler by HVS",
  "version": "1.01",
  "description": "Zoom only the video on YouTube/Shorts. U=in, Y=out. Ctrl+Move to pan. Click still plays/pauses. Seekbar unaffected.",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}